# ─── Database ─────────────────────────────────────────────────────────────────
# Local: Docker Postgres (see docker-compose.yml)
# Production: Supabase — use connection pooling URL (port 6543) for queries
DATABASE_URL="postgresql://postgres:password@localhost:5432/cardwise"

# Supabase migrations require direct connection (port 5432)
# Local: same as DATABASE_URL
# Production: Supabase direct connection URL from Project Settings → Database
DIRECT_URL="postgresql://postgres:password@localhost:5432/cardwise"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# Local: http://localhost:3000
# Production: https://your-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth (optional) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
