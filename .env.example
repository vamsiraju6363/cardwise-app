# ─── Database ─────────────────────────────────────────────────────────────────
# Local: Docker Postgres (see docker-compose.yml)
# Production: Supabase Transaction pooler — port 6543, host: aws-0-[region].pooler.supabase.com
DATABASE_URL="postgresql://postgres:password@localhost:5432/cardwise"

# Supabase migrations require DIRECT connection (different host!)
# Local: same as DATABASE_URL
# Production: host is db.[project-ref].supabase.co (NOT pooler.supabase.com)
# Get from Supabase → Project Settings → Database → Connection string → Direct connection
DIRECT_URL="postgresql://postgres:password@localhost:5432/cardwise"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# Local: http://localhost:3000
# Production: https://your-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth (optional) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
